/**pages/coach/schedule/schedule.wxss**/

.container {
  padding: 0;
  background-color: #f5f5f5;
  min-height: 100vh;
  padding-bottom: 140rpx;
}

/* 教练信息栏 */
.coach-header {
  background: linear-gradient(135deg, #667eea, #764ba2);
  padding: 40rpx;
  color: white;
  display: flex;
  justify-content: space-between;
}

.coach-info {
  display: flex;
  align-items: center;
}

.coach-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  font-size: 28rpx;
}

.coach-details {
  display: flex;
  flex-direction: column;
}

.coach-name {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.coach-title {
  font-size: 24rpx;
  opacity: 0.9;
}

.coach-stats {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.stat-item {
  text-align: right;
  margin-bottom: 10rpx;
}

.stat-number {
  font-size: 36rpx;
  font-weight: bold;
  display: block;
}

.stat-label {
  font-size: 24rpx;
  opacity: 0.9;
}

/* 日期选择器 */
.date-selector {
  background: white;
  padding: 30rpx 40rpx;
  display: flex;
  justify-content: center;
}

.picker-display {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.arrow {
  margin-left: 10rpx;
  font-size: 32rpx;
  color: #667eea;
}

/* 筛选标签 */
.filter-tabs {
  display: flex;
  background: white;
  border-bottom: 1rpx solid #eee;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 28rpx;
  color: #666;
}

.tab.active {
  color: #667eea;
  font-weight: bold;
  position: relative;
}

.tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 6rpx;
  background: #667eea;
  border-radius: 3rpx;
}

/* 课程时间轴 */
.schedule-timeline {
  padding: 20rpx;
}

.timeline-item {
  display: flex;
  margin-bottom: 20rpx;
}

.time-slot {
  width: 120rpx;
  text-align: center;
  padding: 20rpx 10rpx;
  flex-shrink: 0;
}

.time {
  display: block;
  font-size: 24rpx;
  color: #999;
}

.class-card {
  flex: 1;
  background: white;
  border-radius: 15rpx;
  padding: 25rpx;
  margin-left: 10rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
}

.class-card.ongoing {
  border-left: 6rpx solid #52c41a;
}

.class-card.upcoming {
  border-left: 6rpx solid #1890ff;
}

.class-card.completed {
  border-left: 6rpx solid #bfbfbf;
}

.class-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 15rpx;
}

.class-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  flex: 1;
  margin-right: 20rpx;
}

.class-type {
  font-size: 24rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.class-type.group {
  background-color: #e6f7ff;
  color: #1890ff;
}

.class-type.private {
  background-color: #f6ffed;
  color: #52c41a;
}

.class-meta {
  display: flex;
  justify-content: space-between;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 10rpx;
}

.class-students {
  color: #666;
}

.class-status {
  font-weight: bold;
}

.class-status.ongoing {
  color: #52c41a;
}

.class-status.upcoming {
  color: #1890ff;
}

.class-status.completed {
  color: #bfbfbf;
}

.class-location {
  font-size: 24rpx;
  color: #999;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 120rpx 40rpx;
  color: #999;
  font-size: 28rpx;
}

/* 快速操作 */
.quick-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 40rpx;
  background: white;
  border-top: 1rpx solid #eee;
  display: flex;
  gap: 20rpx;
}

.action-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: bold;
  background: #667eea;
  color: white;
  border: none;
}