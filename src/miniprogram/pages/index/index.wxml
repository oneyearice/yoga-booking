<!--index.wxml-->
<view class="container">
  <!-- 头部区域 -->
  <view class="header">
    <view class="welcome">
      <text class="greeting">欢迎来到瑜伽馆</text>
      <text class="username">{{userInfo.nickName || '游客'}}</text>
    </view>
    <view class="quick-actions">
      <button class="action-btn primary" bindtap="goToBooking">立即预约</button>
      <button class="action-btn secondary" bindtap="goToCourses">查看课程</button>
    </view>
  </view>

  <!-- 课程分类 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">课程分类</text>
    </view>
    <scroll-view class="category-scroll" scroll-x="true">
      <view class="category-list">
        <view class="category-item" wx:for="{{categories}}" wx:key="id" bindtap="filterByCategory" data-category="{{item}}">
          <view class="category-icon">{{item.icon}}</view>
          <text class="category-name">{{item.name}}</text>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- 推荐课程 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">推荐课程</text>
    </view>
    <view class="course-grid">
      <view class="course-card" wx:for="{{recommendedCourses}}" wx:key="id" bindtap="viewCourseDetail" data-course="{{item}}">
        <image class="course-image" src="{{item.coverImage}}" mode="aspectFill"></image>
        <view class="course-info">
          <text class="course-name">{{item.name}}</text>
          <text class="course-time">{{item.duration}}分钟 | {{item.coachName}}</text>
          <view class="course-meta">
            <text class="course-price">¥{{item.price}}</text>
            <text class="course-spots">{{item.capacity - item.bookedCount}}/{{item.capacity}}名额</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 预约提醒 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">我的预约</text>
      <text class="section-more" bindtap="viewMyBookings">查看更多 ></text>
    </view>
    <view class="booking-preview" wx:if="{{myBookings.length > 0}}">
      <view class="booking-item" wx:for="{{myBookings}}" wx:key="id" bindtap="viewBookingDetail" data-booking="{{item}}">
        <view class="booking-course">{{item.courseName}}</view>
        <view class="booking-time">{{item.startTime}}</view>
        <view class="booking-status {{item.status}}">{{item.statusText}}</view>
      </view>
    </view>
    <view class="empty-state" wx:else>
      <text>暂无预约记录</text>
    </view>
  </view>
</view>