/**index.wxss**/

.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

/* 头部区域 */
.header {
  background: linear-gradient(135deg, #667eea, #764ba2);
  border-radius: 20rpx;
  padding: 40rpx;
  margin-bottom: 30rpx;
  color: white;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.1);
}

.welcome {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.greeting {
  font-size: 36rpx;
  font-weight: bold;
}

.username {
  font-size: 32rpx;
  opacity: 0.9;
}

.quick-actions {
  display: flex;
  justify-content: center;
  gap: 20rpx;
}

.action-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  border-radius: 40rpx;
  font-size: 32rpx;
  font-weight: bold;
}

.action-btn.primary {
  background-color: #fff;
  color: #667eea;
}

.action-btn.secondary {
  background-color: rgba(255,255,255,0.2);
  color: #fff;
  border: 2rpx solid rgba(255,255,255,0.3);
}

/* 区块样式 */
.section {
  background: white;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.section-more {
  font-size: 28rpx;
  color: #667eea;
}

/* 分类滚动 */
.category-scroll {
  white-space: nowrap;
  padding: 20rpx 0;
}

.category-list {
  display: inline-flex;
  gap: 30rpx;
}

.category-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx;
  background: #f9f9f9;
  border-radius: 15rpx;
  min-width: 120rpx;
}

.category-icon {
  font-size: 48rpx;
  margin-bottom: 10rpx;
}

.category-name {
  font-size: 28rpx;
  color: #666;
}

/* 课程网格 */
.course-grid {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.course-card {
  display: flex;
  border: 1rpx solid #eee;
  border-radius: 15rpx;
  overflow: hidden;
  background: white;
}

.course-image {
  width: 200rpx;
  height: 150rpx;
}

.course-info {
  flex: 1;
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.course-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.course-time {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 10rpx;
}

.course-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.course-price {
  font-size: 32rpx;
  font-weight: bold;
  color: #ff6b6b;
}

.course-spots {
  font-size: 26rpx;
  color: #999;
}

/* 预约预览 */
.booking-preview {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.booking-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  border: 1rpx solid #eee;
  border-radius: 10rpx;
  background: #fafafa;
}

.booking-course {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.booking-time {
  font-size: 28rpx;
  color: #666;
}

.booking-status.confirmed {
  color: #2ecc71;
  font-weight: bold;
}

.booking-status.pending {
  color: #f39c12;
  font-weight: bold;
}

.empty-state {
  text-align: center;
  padding: 60rpx 0;
  color: #999;
  font-size: 28rpx;
}