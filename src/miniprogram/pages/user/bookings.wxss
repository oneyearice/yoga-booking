/**user/bookings/bookings.wxss**/

.container {
  padding: 0;
  background-color: #f5f5f5;
  min-height: 100vh;
}

/* 标题栏 */
.title-bar {
  background: white;
  padding: 30rpx 40rpx;
  text-align: center;
  border-bottom: 1rpx solid #eee;
  position: sticky;
  top: 0;
  z-index: 100;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

/* 标签容器 */
.tab-container {
  display: flex;
  background: white;
  border-bottom: 1rpx solid #eee;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 25rpx 0;
  font-size: 28rpx;
  color: #666;
  position: relative;
}

.tab-item.active {
  color: #667eea;
  font-weight: bold;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 6rpx;
  background: #667eea;
  border-radius: 3rpx;
}

/* 预约列表 */
.booking-list {
  padding: 20rpx;
}

.booking-card {
  background: white;
  border-radius: 15rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.course-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.status {
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.status.upcoming {
  background-color: #e6f7ff;
  color: #1890ff;
}

.status.completed {
  background-color: #f6ffed;
  color: #52c41a;
}

.status.cancelled {
  background-color: #fff2e8;
  color: #fa8c16;
}

/* 信息行 */
.info-row {
  display: flex;
  margin-bottom: 15rpx;
  font-size: 26rpx;
  color: #666;
}

.info-row:last-child {
  margin-bottom: 0;
}

.label {
  width: 100rpx;
  color: #999;
}

.value {
  flex: 1;
  color: #333;
}

/* 卡片底部 */
.card-footer {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f5f5f5;
  font-size: 24rpx;
  color: #999;
}

.booking-id {
  display: block;
  margin-bottom: 10rpx;
}

.booking-time {
  display: block;
}

/* 操作按钮 */
.action-buttons {
  display: flex;
  gap: 20rpx;
  margin-top: 25rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f5f5f5;
}

.action-buttons .btn {
  flex: 1;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  border-radius: 30rpx;
  font-size: 26rpx;
}

.btn-outline {
  background-color: transparent;
  color: #667eea;
  border: 1rpx solid #667eea;
}

.btn-primary {
  background-color: #667eea;
  color: white;
  border: none;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 120rpx 40rpx;
  color: #999;
  font-size: 28rpx;
}