/**user/index/index.wxss**/

.container {
  padding: 0;
  background-color: #f5f5f5;
  min-height: 100vh;
}

/* 用户信息头部 */
.user-header {
  background: linear-gradient(135deg, #667eea, #764ba2);
  padding: 60rpx 40rpx 40rpx;
  color: white;
  position: relative;
}

.avatar-container {
  display: flex;
  align-items: center;
  margin-bottom: 40rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  margin-right: 30rpx;
  border: 4rpx solid rgba(255,255,255,0.3);
}

.nickname {
  font-size: 36rpx;
  font-weight: bold;
}

.credit-info {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: rgba(255,255,255,0.2);
  padding: 20rpx 30rpx;
  border-radius: 15rpx;
  backdrop-filter: blur(10rpx);
}

.credit-label {
  font-size: 28rpx;
  opacity: 0.9;
}

.credit-count {
  font-size: 32rpx;
  font-weight: bold;
}

.icon {
  font-size: 32rpx;
  opacity: 0.8;
}

/* 快捷功能区 */
.quick-actions {
  display: flex;
  background: white;
  padding: 30rpx 20rpx;
  margin: 20rpx;
  border-radius: 15rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
}

.action-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.action-icon {
  font-size: 48rpx;
  margin-bottom: 10rpx;
}

.action-text {
  font-size: 26rpx;
  color: #666;
}

/* 功能列表 */
.function-list {
  background: white;
  margin: 0 20rpx 20rpx;
  border-radius: 15rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
}

.list-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.list-item:last-child {
  border-bottom: none;
}

.item-left {
  display: flex;
  align-items: center;
}

.item-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.item-text {
  font-size: 28rpx;
  color: #333;
}

.item-right {
  font-size: 32rpx;
  color: #ccc;
}

/* 预约状态概览 */
.booking-overview {
  background: white;
  margin: 0 20rpx 20rpx;
  border-radius: 15rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
}

.overview-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 30rpx;
  display: block;
}

.stats-grid {
  display: flex;
  justify-content: space-around;
}

.stat-item {
  text-align: center;
  flex: 1;
}

.stat-number {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #667eea;
  margin-bottom: 10rpx;
}

.stat-label {
  font-size: 26rpx;
  color: #666;
}