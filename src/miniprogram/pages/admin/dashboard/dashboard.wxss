/**pages/admin/dashboard/dashboard.wxss**/

.container {
  padding: 0;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.page-title {
  background: linear-gradient(135deg, #667eea, #764ba2);
  padding: 40rpx;
  color: white;
  font-size: 40rpx;
  font-weight: bold;
  text-align: center;
}

/* 统计卡片 */
.stats-container {
  padding: 30rpx;
}

.stat-card-group {
  display: flex;
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.stat-card {
  flex: 1;
  display: flex;
  align-items: center;
  background: white;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
  transition: all 0.2s ease;
}

.stat-card:hover,
.stat-card:active {
  opacity: 0.85;
  transform: scale(0.98);
}

.card-icon {
  font-size: 48rpx;
  margin-right: 20rpx;
}

.card-content {
  flex: 1;
}

.stat-number {
  font-size: 40rpx;
  font-weight: bold;
  color: #667eea;
  margin-bottom: 10rpx;
}

.stat-label {
  font-size: 26rpx;
  color: #666;
}

/* 区块样式 */
.section {
  background: white;
  border-radius: 20rpx;
  padding: 30rpx;
  margin: 0 20rpx 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.refresh-btn {
  font-size: 32rpx;
  padding: 10rpx;
  border-radius: 50%;
  background: #f5f5f5;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 活动列表 */
.activities-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.activity-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  border: 1rpx solid #eee;
  border-radius: 15rpx;
  background: #fafafa;
}

.activity-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.activity-content {
  flex: 1;
}

.activity-text {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 5rpx;
}

.activity-time {
  font-size: 24rpx;
  color: #999;
}

.activity-status {
  font-size: 32rpx;
  margin-left: 20rpx;
}

.activity-status.confirmed {
  color: #2ecc71;
}

.activity-status.pending {
  color: #f39c12;
}

.activity-status.registered {
  color: #3498db;
}

/* 加载状态 */
.loading-container {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 100rpx 0;
}

.loading-text {
  font-size: 28rpx;
  color: #666;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 100rpx 0;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}