<!--pages/admin/users/users.wxml-->
<view class="container">
  <!-- 顶部操作栏 -->
  <view class="top-actions">
    <button class="action-btn primary" bindtap="addUser">➕ 添加用户</button>
    <button class="action-btn secondary" bindtap="importUsers">📥 导入用户</button>
    <button class="action-btn secondary" bindtap="exportUsers">📤 导出用户</button>
    <button class="action-btn secondary" bindtap="refreshList">🔄 刷新</button>
  </view>

  <!-- 搜索和筛选 -->
  <view class="search-filter">
    <input 
      class="search-input" 
      placeholder="搜索用户名/手机号/邮箱" 
      value="{{searchKeyword}}" 
      bindinput="onSearchInput"
    />
    <button class="search-btn" bindtap="onSearch">搜索</button>
    
    <view class="filter-options">
      <picker class="filter-picker" range="{{roleOptions}}" bindchange="onRoleChange">
        <view class="picker-label">角色: {{roleOptions[roleIndex]}}</view>
      </picker>
      <picker class="filter-picker" range="{{statusOptions}}" bindchange="onStatusChange">
        <view class="picker-label">状态: {{statusOptions[statusIndex]}}</view>
      </picker>
    </view>
  </view>

  <!-- 用户列表 -->
  <view class="user-list">
    <view class="user-item" wx:for="{{userList}}" wx:key="id">
      <view class="user-avatar">{{item.avatar || '👤'}}</view>
      
      <view class="user-info">
        <view class="user-header">
          <text class="user-name">{{item.name}}</text>
          <view class="user-tags">
            <text class="tag role {{item.role}}">{{item.roleText}}</text>
            <text class="tag status {{item.status}}">{{item.statusText}}</text>
          </view>
        </view>
        
        <view class="user-meta">
          <text class="meta-item">手机号: {{item.phone}}</text>
          <text class="meta-item">邮箱: {{item.email}}</text>
          <text class="meta-item">注册时间: {{item.registerTime}}</text>
          <text class="meta-item">课时余额: {{item.creditBalance}}</text>
        </view>
        
        <view class="user-stats">
          <text class="stat-item">预约次数: {{item.bookingCount}}</text>
          <text class="stat-item">上课次数: {{item.attendanceCount}}</text>
          <text class="stat-item">消费金额: ¥{{item.totalSpent}}</text>
        </view>
      </view>
      
      <view class="user-actions">
        <button class="action-btn edit" bindtap="editUser" data-user="{{item}}">编辑</button>
        <button class="action-btn reset" bindtap="resetPassword" data-id="{{item.id}}">重置密码</button>
        <button class="action-btn toggle" bindtap="toggleUserStatus" data-id="{{item.id}}" data-status="{{item.status}}">
          {{item.status === 'active' ? '禁用' : '启用'}}
        </button>
        <button class="action-btn delete" bindtap="deleteUser" data-id="{{item.id}}">删除</button>
      </view>
    </view>
  </view>

  <!-- 分页 -->
  <view class="pagination" wx:if="{{totalPages > 1}}">
    <button class="page-btn" bindtap="prevPage" disabled="{{currentPage <= 1}}">上一页</button>
    <text class="page-info">{{currentPage}} / {{totalPages}}</text>
    <button class="page-btn" bindtap="nextPage" disabled="{{currentPage >= totalPages}}">下一页</button>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{userList.length === 0}}">
    <text>{{emptyText}}</text>
  </view>

  <!-- 添加/编辑用户弹窗 -->
  <view class="modal" wx:if="{{showUserModal}}">
    <view class="modal-content">
      <view class="modal-header">
        <text class="modal-title">{{modalTitle}}</text>
        <text class="close-btn" bindtap="closeModal">×</text>
      </view>
      <view class="modal-body">
        <view class="form-group">
          <text class="form-label">用户名 *</text>
          <input class="form-input" placeholder="请输入用户名" value="{{formData.name}}" bindinput="onNameInput"/>
        </view>
        <view class="form-group">
          <text class="form-label">手机号 *</text>
          <input class="form-input" placeholder="请输入手机号" value="{{formData.phone}}" bindinput="onPhoneInput" type="number"/>
        </view>
        <view class="form-group">
          <text class="form-label">邮箱</text>
          <input class="form-input" placeholder="请输入邮箱" value="{{formData.email}}" bindinput="onEmailInput" type="text"/>
        </view>
        <view class="form-group">
          <text class="form-label">角色 *</text>
          <picker class="form-picker" range="{{roleOptions}}" range-key="name" bindchange="onFormRoleChange">
            <view class="picker-display">{{formData.roleText || '请选择角色'}}</view>
          </picker>
        </view>
        <view class="form-group">
          <text class="form-label">初始课时</text>
          <input class="form-input" placeholder="请输入初始课时" value="{{formData.creditBalance}}" bindinput="onCreditInput" type="number"/>
        </view>
        <view class="form-group">
          <text class="form-label">用户状态</text>
          <switch class="form-switch" checked="{{formData.status === 'active'}}" bindchange="onStatusSwitchChange"/>
        </view>
      </view>
      <view class="modal-footer">
        <button class="btn btn-secondary" bindtap="closeModal">取消</button>
        <button class="btn btn-primary" bindtap="saveUser">保存</button>
      </view>
    </view>
  </view>

  <!-- 重置密码弹窗 -->
  <view class="modal" wx:if="{{showResetModal}}">
    <view class="modal-content">
      <view class="modal-header">
        <text class="modal-title">重置密码</text>
        <text class="close-btn" bindtap="closeResetModal">×</text>
      </view>
      <view class="modal-body">
        <view class="form-group">
          <text class="form-label">新密码</text>
          <input class="form-input" password placeholder="请输入新密码" value="{{resetPassword}}" bindinput="onNewPasswordInput"/>
        </view>
        <view class="form-group">
          <text class="form-label">确认密码</text>
          <input class="form-input" password placeholder="请再次输入新密码" value="{{confirmPassword}}" bindinput="onConfirmPasswordInput"/>
        </view>
      </view>
      <view class="modal-footer">
        <button class="btn btn-secondary" bindtap="closeResetModal">取消</button>
        <button class="btn btn-primary" bindtap="confirmResetPassword">确认重置</button>
      </view>
    </view>
  </view>
</view>