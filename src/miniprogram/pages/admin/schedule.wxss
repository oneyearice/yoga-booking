/**pages/admin/schedule/schedule.wxss**/

.container {
  padding: 0;
  background-color: #f5f5f5;
  min-height: 100vh;
  padding-bottom: 40rpx;
}

/* 顶部操作栏 */
.top-actions {
  background: white;
  padding: 30rpx 40rpx;
  display: flex;
  gap: 20rpx;
  border-bottom: 1rpx solid #eee;
}

.action-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: bold;
}

.action-btn.primary {
  background: #667eea;
  color: white;
  border: none;
}

.action-btn.secondary {
  background: #f0f0f0;
  color: #666;
  border: 1rpx solid #ddd;
}

/* 日期筛选 */
.date-filter {
  background: white;
  padding: 30rpx 40rpx;
  border-bottom: 1rpx solid #eee;
}

.picker-display {
  display: flex;
  justify-content: space-between;
  align-items: center;
  height: 80rpx;
  line-height: 80rpx;
  padding: 0 20rpx;
  border: 1rpx solid #e5e5e5;
  border-radius: 10rpx;
  font-size: 28rpx;
  color: #333;
}

.arrow {
  font-size: 32rpx;
  color: #667eea;
}

/* 筛选选项 */
.filter-options {
  background: white;
  padding: 20rpx 40rpx;
  border-bottom: 1rpx solid #eee;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.filter-picker {
  margin-bottom: 10rpx;
}

.picker-label {
  display: block;
  padding: 20rpx;
  background: #f9f9f9;
  border-radius: 10rpx;
  font-size: 28rpx;
  color: #333;
}

/* 排课列表 */
.schedule-list {
  padding: 20rpx;
}

.schedule-item {
  background: white;
  border-radius: 15rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
  display: flex;
  flex-direction: column;
}

.schedule-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.schedule-time {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.schedule-date {
  font-size: 26rpx;
  color: #666;
}

.schedule-info {
  margin-bottom: 20rpx;
}

.course-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 10rpx;
}

.coach-name {
  font-size: 28rpx;
  color: #667eea;
  display: block;
  margin-bottom: 15rpx;
}

.schedule-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  font-size: 26rpx;
  color: #666;
}

.location, .capacity {
  margin-right: 20rpx;
}

.status {
  font-weight: bold;
}

.status.active {
  color: #52c41a;
}

.status.full {
  color: #fa8c16;
}

.status.cancelled {
  color: #f5222d;
}

.schedule-actions {
  display: flex;
  gap: 15rpx;
  flex-wrap: wrap;
}

.schedule-actions .action-btn {
  flex: 1;
  height: 60rpx;
  line-height: 60rpx;
  text-align: center;
  border-radius: 30rpx;
  font-size: 24rpx;
  margin: 0;
}

.action-btn.edit {
  background: #f0f0f0;
  color: #666;
  border: 1rpx solid #ddd;
}

.action-btn.delete {
  background: #ff6b6b;
  color: white;
  border: none;
}

.action-btn.toggle {
  background: #667eea;
  color: white;
  border: none;
}

/* 分页 */
.pagination {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 30rpx 40rpx;
  gap: 30rpx;
  background: white;
  margin-top: 20rpx;
}

.page-btn {
  height: 60rpx;
  line-height: 60rpx;
  padding: 0 30rpx;
  background: #f0f0f0;
  color: #666;
  border-radius: 30rpx;
  font-size: 26rpx;
}

.page-btn[disabled] {
  opacity: 0.5;
}

.page-info {
  font-size: 28rpx;
  color: #666;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 120rpx 40rpx;
  color: #999;
  font-size: 28rpx;
}

/* 模态框 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  padding: 40rpx;
}

.modal-content {
  background: white;
  border-radius: 15rpx;
  width: 100%;
  max-width: 600rpx;
  max-height: 80vh;
  overflow-y: auto;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #eee;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.close-btn {
  font-size: 48rpx;
  color: #999;
  line-height: 1;
}

.modal-body {
  padding: 30rpx;
}

.form-group {
  margin-bottom: 30rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 15rpx;
}

.form-input {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  padding: 0 20rpx;
  border: 1rpx solid #e5e5e5;
  border-radius: 10rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.form-picker {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  padding: 0 20rpx;
  border: 1rpx solid #e5e5e5;
  border-radius: 10rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.picker-display {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 28rpx;
}

.radio-group {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.radio-label {
  display: flex;
  align-items: center;
  font-size: 28rpx;
  color: #333;
}

.radio-label radio {
  margin-right: 15rpx;
}

.modal-footer {
  display: flex;
  gap: 20rpx;
  padding: 30rpx;
  border-top: 1rpx solid #eee;
}

.modal-footer .btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: bold;
}

.btn-secondary {
  background: #f0f0f0;
  color: #666;
  border: 1rpx solid #ddd;
}

.btn-primary {
  background: #667eea;
  color: white;
  border: none;
}