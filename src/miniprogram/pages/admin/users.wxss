/**pages/admin/users/users.wxss**/

.container {
  padding: 0;
  background-color: #f5f5f5;
  min-height: 100vh;
  padding-bottom: 40rpx;
}

/* 顶部操作栏 */
.top-actions {
  background: white;
  padding: 30rpx 40rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  border-bottom: 1rpx solid #eee;
}

.action-btn {
  flex: 1;
  min-width: 200rpx;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: bold;
}

.action-btn.primary {
  background: #667eea;
  color: white;
  border: none;
}

.action-btn.secondary {
  background: #f0f0f0;
  color: #666;
  border: 1rpx solid #ddd;
}

/* 搜索和筛选 */
.search-filter {
  background: white;
  padding: 30rpx 40rpx;
  border-bottom: 1rpx solid #eee;
}

.search-input {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  padding: 0 20rpx;
  border: 1rpx solid #e5e5e5;
  border-radius: 40rpx;
  font-size: 28rpx;
  margin-bottom: 20rpx;
}

.search-btn {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  background: #667eea;
  color: white;
  border-radius: 40rpx;
  font-size: 28rpx;
  margin-bottom: 20rpx;
  border: none;
}

.filter-options {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.filter-picker {
  margin-bottom: 10rpx;
}

.picker-label {
  display: block;
  padding: 20rpx;
  background: #f9f9f9;
  border-radius: 10rpx;
  font-size: 28rpx;
  color: #333;
}

/* 用户列表 */
.user-list {
  padding: 20rpx;
}

.user-item {
  background: white;
  border-radius: 15rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
  display: flex;
  flex-direction: column;
}

.user-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  margin-bottom: 20rpx;
  align-self: flex-start;
}

.user-info {
  flex: 1;
  margin-bottom: 20rpx;
}

.user-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 20rpx;
}

.user-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-right: 20rpx;
}

.user-tags {
  display: flex;
  gap: 10rpx;
}

.tag {
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.tag.role {
  background: #eef7ff;
  color: #4a90e2;
}

.tag.role.coach {
  background: #fff0f6;
  color: #eb2f96;
}

.tag.role.admin {
  background: #f9f0ff;
  color: #b75ae0;
}

.tag.status {
  background: #f6ffed;
  color: #5cb860;
}

.tag.status.inactive {
  background: #fff2e8;
  color: #fa8c16;
}

.user-meta {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  margin-bottom: 20rpx;
  font-size: 26rpx;
  color: #666;
}

.meta-item {
  display: flex;
  justify-content: space-between;
}

.user-stats {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  font-size: 24rpx;
  color: #888;
  padding-top: 20rpx;
  border-top: 1rpx solid #f5f5f5;
}

.stat-item {
  margin-right: 30rpx;
}

.user-actions {
  display: flex;
  gap: 15rpx;
  flex-wrap: wrap;
}

.user-actions .action-btn {
  flex: 1;
  min-width: 120rpx;
  height: 60rpx;
  line-height: 60rpx;
  text-align: center;
  border-radius: 30rpx;
  font-size: 24rpx;
  margin: 0;
}

.action-btn.edit {
  background: #f0f0f0;
  color: #666;
  border: 1rpx solid #ddd;
}

.action-btn.reset {
  background: #f0f0f0;
  color: #666;
  border: 1rpx solid #ddd;
}

.action-btn.toggle {
  background: #667eea;
  color: white;
  border: none;
}

.action-btn.delete {
  background: #ff6b6b;
  color: white;
  border: none;
}

/* 分页 */
.pagination {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 30rpx 40rpx;
  gap: 30rpx;
  background: white;
  margin-top: 20rpx;
}

.page-btn {
  height: 60rpx;
  line-height: 60rpx;
  padding: 0 30rpx;
  background: #f0f0f0;
  color: #666;
  border-radius: 30rpx;
  font-size: 26rpx;
}

.page-btn[disabled] {
  opacity: 0.5;
}

.page-info {
  font-size: 28rpx;
  color: #666;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 120rpx 40rpx;
  color: #999;
  font-size: 28rpx;
}

/* 模态框 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  padding: 40rpx;
}

.modal-content {
  background: white;
  border-radius: 15rpx;
  width: 100%;
  max-width: 600rpx;
  max-height: 80vh;
  overflow-y: auto;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #eee;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.close-btn {
  font-size: 48rpx;
  color: #999;
  line-height: 1;
}

.modal-body {
  padding: 30rpx;
}

.form-group {
  margin-bottom: 30rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 15rpx;
}

.form-input {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  padding: 0 20rpx;
  border: 1rpx solid #e5e5e5;
  border-radius: 10rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.form-picker {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  padding: 0 20rpx;
  border: 1rpx solid #e5e5e5;
  border-radius: 10rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.picker-display {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 28rpx;
}

.form-switch {
  transform: scale(0.8);
}

.modal-footer {
  display: flex;
  gap: 20rpx;
  padding: 30rpx;
  border-top: 1rpx solid #eee;
}

.modal-footer .btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: bold;
}

.btn-secondary {
  background: #f0f0f0;
  color: #666;
  border: 1rpx solid #ddd;
}

.btn-primary {
  background: #667eea;
  color: white;
  border: none;
}