/**pages/booking/list/detail/detail.wxss**/

.container {
  padding: 0;
  background-color: #f5f5f5;
  min-height: 100vh;
  padding-bottom: 160rpx; /* 为底部按钮留出空间 */
}

/* 顶部栏 */
.header-bar {
  display: flex;
  align-items: center;
  background: white;
  padding: 30rpx 40rpx;
  border-bottom: 1rpx solid #eee;
}

.back-btn {
  font-size: 36rpx;
  margin-right: 20rpx;
  padding: 10rpx;
}

.page-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

/* 加载状态 */
.loading-container {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 100rpx 0;
}

.loading-text {
  font-size: 28rpx;
  color: #666;
}

/* 状态卡片 */
.status-card {
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: white;
  padding: 60rpx 40rpx;
  margin: 20rpx;
  border-radius: 20rpx;
  text-align: center;
}

.status-card.confirmed {
  background: linear-gradient(135deg, #2ecc71, #27ae60);
}

.status-card.pending {
  background: linear-gradient(135deg, #f39c12, #e67e22);
}

.status-card.cancelled {
  background: linear-gradient(135deg, #95a5a6, #7f8c8d);
}

.status-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
  display: block;
}

.status-text {
  font-size: 48rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
  display: block;
}

.status-time {
  font-size: 28rpx;
  opacity: 0.9;
  display: block;
}

/* 区块样式 */
.section {
  background: white;
  margin: 20rpx;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 30rpx;
  display: block;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.info-row:last-child {
  border-bottom: none;
}

.label {
  font-size: 28rpx;
  color: #666;
  width: 140rpx;
}

.value {
  font-size: 28rpx;
  color: #333;
  flex: 1;
  text-align: right;
  word-break: break-all;
}

/* 底部操作按钮 */
.bottom-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  padding: 20rpx 40rpx;
  background: white;
  border-top: 1rpx solid #eee;
  box-shadow: 0 -4rpx 12rpx rgba(0,0,0,0.05);
  gap: 20rpx;
}

.action-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  border-radius: 40rpx;
  font-size: 32rpx;
  font-weight: bold;
  transition: all 0.2s ease;
}

.action-btn:hover,
.action-btn:active {
  opacity: 0.85;
  transform: scale(0.98);
}

.action-btn.primary {
  background: #667eea;
  color: white;
}

.action-btn.secondary {
  background: #f5f5f5;
  color: #667eea;
  border: 1rpx solid #e5e5e5;
}

.action-btn.disabled {
  background: #f5f5f5;
  color: #999;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 200rpx 40rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}