/**booking/list/list.wxss**/

.container {
  padding: 0;
  background-color: #f5f5f5;
  min-height: 100vh;
}

/* 标签页 */
.tab-bar {
  display: flex;
  background: white;
  border-bottom: 1rpx solid #eee;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 28rpx;
  color: #666;
}

.tab-item.active {
  color: #667eea;
  font-weight: bold;
  position: relative;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 6rpx;
  background: #667eea;
  border-radius: 3rpx;
}

/* 预约列表 */
.booking-list {
  padding: 20rpx;
}

.booking-item {
  background: white;
  border-radius: 15rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
}

.course-info {
  display: flex;
  padding: 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.course-image {
  width: 160rpx;
  height: 120rpx;
  border-radius: 10rpx;
  margin-right: 20rpx;
}

.course-details {
  flex: 1;
}

.course-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
  display: block;
}

.coach-info {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 10rpx;
  display: block;
}

.booking-time {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 10rpx;
  display: block;
}

.booking-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.booking-status {
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.booking-status.upcoming {
  background-color: #e6f7ff;
  color: #1890ff;
}

.booking-status.completed {
  background-color: #f6ffed;
  color: #52c41a;
}

.booking-status.cancelled {
  background-color: #fff2e8;
  color: #fa8c16;
}

.people-count {
  font-size: 24rpx;
  color: #999;
}

/* 操作按钮 */
.action-buttons {
  display: flex;
  padding: 20rpx 30rpx;
  gap: 20rpx;
  flex-wrap: wrap;
}

.action-buttons .btn {
  flex: 1;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  border-radius: 30rpx;
  font-size: 26rpx;
  margin: 0;
  min-width: 140rpx;
}

.action-buttons .btn:last-child {
  margin-right: 0;
}

.btn-outline {
  background-color: transparent;
  color: #667eea;
  border: 1rpx solid #667eea;
}

.btn-primary {
  background-color: #ff6b6b;
  color: white;
  border: none;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 120rpx 40rpx;
  color: #999;
  font-size: 28rpx;
}