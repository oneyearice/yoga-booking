/**booking/confirm/confirm.wxss**/

.container {
  padding: 0;
  background-color: #f5f5f5;
  min-height: 100vh;
  padding-bottom: 140rpx; /* 为底部按钮留出空间 */
}

/* 课程卡片 */
.course-card {
  margin: 0;
  border-radius: 0;
  display: flex;
  padding: 30rpx;
}

.course-image {
  width: 180rpx;
  height: 140rpx;
  border-radius: 10rpx;
  margin-right: 20rpx;
}

.course-info {
  flex: 1;
}

.course-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 20rpx;
}

.course-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  flex: 1;
  margin-right: 20rpx;
}

.course-price {
  font-size: 36rpx;
  font-weight: bold;
  color: #ff6b6b;
}

.course-meta {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.meta-item {
  font-size: 26rpx;
  color: #666;
}

/* 预约信息 */
.booking-info {
  margin: 0;
  border-radius: 0;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.info-row:last-child {
  border-bottom: none;
}

.label {
  font-size: 28rpx;
  color: #666;
  width: 120rpx;
}

.value {
  font-size: 28rpx;
  color: #333;
  flex: 1;
  text-align: right;
}

.picker {
  width: 100%;
  text-align: right;
  color: #333;
}

.input-field {
  width: 100%;
  text-align: right;
  font-size: 28rpx;
  color: #333;
}

.textarea-field {
  width: 100%;
  min-height: 120rpx;
  text-align: right;
  font-size: 28rpx;
  color: #333;
  border: none;
  padding: 0;
}

/* 费用信息 */
.fee-info {
  margin: 0;
  border-radius: 0;
}

.fee-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.fee-row:last-child {
  border-bottom: none;
}

.fee-row.total {
  padding-top: 30rpx;
  padding-bottom: 30rpx;
  background-color: #fff9f9;
}

.total-price {
  font-size: 36rpx;
  font-weight: bold;
  color: #ff6b6b;
}

/* 课时余额 */
.balance-info {
  margin: 0;
  border-radius: 0;
}

.balance-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.balance-row:last-child {
  border-bottom: none;
}

/* 注意事项 */
.notice {
  margin: 0;
  border-radius: 0;
}

.notice-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 20rpx;
}

.notice-item:last-child {
  margin-bottom: 0;
}

.bullet {
  font-size: 28rpx;
  color: #667eea;
  margin-right: 10rpx;
  margin-top: 4rpx;
}

.notice-text {
  font-size: 26rpx;
  color: #666;
  flex: 1;
  line-height: 1.5;
}

/* 底部按钮 */
.bottom-action {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 40rpx;
  background: white;
  border-top: 1rpx solid #eee;
  box-shadow: 0 -4rpx 12rpx rgba(0,0,0,0.05);
}

.confirm-btn {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  border-radius: 40rpx;
  font-size: 32rpx;
  font-weight: bold;
  transition: all 0.2s ease;
}

.confirm-btn:hover,
.confirm-btn:active {
  opacity: 0.85;
  transform: scale(0.98);
}