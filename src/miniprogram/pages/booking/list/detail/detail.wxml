<!--pages/booking/list/detail/detail.wxml-->
<view class="container">
  <!-- 返回按钮 -->
  <view class="header-bar">
    <view class="back-btn" bindtap="goBack">
      <text>←</text>
    </view>
    <view class="page-title">
      <text>预约详情</text>
    </view>
  </view>

  <!-- 加载状态 -->
  <view class="loading-container" wx:if="{{loading}}">
    <view class="loading-text">加载中...</view>
  </view>

  <!-- 预约详情内容 -->
  <view wx:if="{{!loading}}">
    <!-- 预约状态卡片 -->
    <view class="status-card {{bookingDetail.status}}">
      <view class="status-icon">
        <text wx:if="{{bookingDetail.status == 'confirmed'}}">✅</text>
        <text wx:if="{{bookingDetail.status == 'pending'}}">⏳</text>
        <text wx:if="{{bookingDetail.status == 'cancelled'}}">❌</text>
      </view>
      <view class="status-text">
        <text>{{bookingDetail.statusText}}</text>
      </view>
      <view class="status-time">
        <text>{{bookingDetail.bookingTime}}</text>
      </view>
    </view>

    <!-- 课程信息 -->
    <view class="section">
      <view class="section-title">课程信息</view>
      <view class="info-row">
        <view class="label">课程名称</view>
        <view class="value">{{bookingDetail.courseName}}</view>
      </view>
      <view class="info-row">
        <view class="label">教练</view>
        <view class="value">{{bookingDetail.coachName}}</view>
      </view>
      <view class="info-row">
        <view class="label">日期</view>
        <view class="value">{{bookingDetail.date}}</view>
      </view>
      <view class="info-row">
        <view class="label">时间</view>
        <view class="value">{{bookingDetail.time}}</view>
      </view>
      <view class="info-row">
        <view class="label">时长</view>
        <view class="value">{{bookingDetail.duration}}分钟</view>
      </view>
      <view class="info-row">
        <view class="label">价格</view>
        <view class="value">¥{{bookingDetail.price}}</view>
      </view>
    </view>

    <!-- 学员信息 -->
    <view class="section">
      <view class="section-title">学员信息</view>
      <view class="info-row">
        <view class="label">姓名</view>
        <view class="value">{{bookingDetail.studentName}}</view>
      </view>
      <view class="info-row">
        <view class="label">手机号</view>
        <view class="value">{{bookingDetail.studentPhone}}</view>
      </view>
    </view>

    <!-- 预约信息 -->
    <view class="section">
      <view class="section-title">预约信息</view>
      <view class="info-row">
        <view class="label">预约时间</view>
        <view class="value">{{bookingDetail.bookingTime}}</view>
      </view>
      <view class="info-row">
        <view class="label">支付状态</view>
        <view class="value">{{bookingDetail.paymentStatus == 'paid' ? '已支付' : '未支付'}}</view>
      </view>
      <view class="info-row">
        <view class="label">支付方式</view>
        <view class="value">{{bookingDetail.paymentMethod}}</view>
      </view>
      <view class="info-row" wx:if="{{bookingDetail.specialRequirements != '无'}}">
        <view class="label">特殊要求</view>
        <view class="value">{{bookingDetail.specialRequirements}}</view>
      </view>
    </view>

    <!-- 底部操作按钮 -->
    <view class="bottom-actions">
      <view class="action-btn secondary" bindtap="contactCoach">
        <text>联系教练</text>
      </view>
      <view class="action-btn primary" bindtap="cancelBooking" wx:if="{{bookingDetail.status == 'confirmed'}}">
        <text>取消预约</text>
      </view>
      <view class="action-btn disabled" wx:if="{{bookingDetail.status != 'confirmed'}}">
        <text>{{bookingDetail.status == 'pending' ? '待确认' : '已取消'}}</text>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{!loading && !bookingDetail}}">
    <view class="empty-text">未找到预约信息</view>
  </view>
</view>