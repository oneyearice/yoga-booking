/**courses/detail/detail.wxss**/

.container {
  padding: 0;
  background-color: #f5f5f5;
  min-height: 100vh;
  padding-bottom: 140rpx; /* 为底部操作栏留出空间 */
}

/* 课程封面 */
.course-banner {
  position: relative;
  height: 400rpx;
  overflow: hidden;
}

.banner-image {
  width: 100%;
  height: 100%;
}

.banner-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: linear-gradient(transparent, rgba(0,0,0,0.7));
  padding: 60rpx 40rpx 40rpx;
  color: white;
}

.course-name {
  font-size: 48rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 10rpx;
}

.course-price {
  font-size: 40rpx;
  font-weight: bold;
  color: #ffd700;
}

/* 课程信息 */
.course-info {
  margin: 0;
  border-radius: 0;
  border-bottom: 1rpx solid #eee;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 28rpx;
  color: #666;
  width: 120rpx;
}

.info-value {
  font-size: 28rpx;
  color: #333;
  flex: 1;
  text-align: right;
}

.remaining-spots {
  color: #ff6b6b;
  font-weight: bold;
}

/* 课程描述 */
.course-description {
  margin: 0;
  border-radius: 0;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  display: block;
}

.description-text {
  font-size: 28rpx;
  line-height: 1.6;
  color: #666;
}

/* 教练信息 */
.coach-info {
  margin: 0;
  border-radius: 0;
}

.coach-profile {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
}

.coach-avatar {
  font-size: 80rpx;
  margin-right: 20rpx;
}

.coach-details {
  flex: 1;
}

.coach-name {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.coach-desc {
  font-size: 26rpx;
  color: #666;
}

/* 可预约时间 */
.schedule-section {
  margin: 0;
  border-radius: 0;
}

.time-slots {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-top: 20rpx;
}

.time-slot {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  border: 1rpx solid #e5e5e5;
  border-radius: 10rpx;
}

.time-slot.available {
  background: #f0f9ff;
  border-color: #b3d8ff;
}

.time-slot.unavailable {
  background: #f5f5f5;
  color: #ccc;
  border-color: #e5e5e5;
}

.time {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.date {
  font-size: 28rpx;
  color: #666;
  margin: 0 20rpx;
}

.status {
  font-size: 26rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.status.available {
  color: #5cb860;
  background: #eaf6ef;
}

.status.unavailable {
  color: #999;
  background: #f5f5f5;
}

/* 底部操作栏 */
.bottom-action {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  padding: 20rpx 40rpx;
  background: white;
  border-top: 1rpx solid #eee;
  box-shadow: 0 -4rpx 12rpx rgba(0,0,0,0.05);
}

.action-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  border-radius: 40rpx;
  font-size: 32rpx;
  font-weight: bold;
  margin: 0 10rpx;
  transition: all 0.2s ease;
}

.action-btn:first-child {
  margin-left: 0;
}

.action-btn:last-child {
  margin-right: 0;
}

.action-btn[disabled] {
  opacity: 0.5;
}

.action-btn:hover,
.action-btn:active {
  opacity: 0.85;
  transform: scale(0.98);
}