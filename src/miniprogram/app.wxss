/**
 * app.wxss
 * 全局样式
 */

/* 全局变量定义 */
page {
  font-size: 28rpx;
  line-height: 1.6;
  color: #333;
  background-color: #f5f5f5;
}

/* 通用容器样式 */
.container {
  padding: 20rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

/* 按钮样式 */
.btn {
  display: block;
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  border-radius: 40rpx;
  font-size: 32rpx;
  font-weight: bold;
  box-sizing: border-box;
}

.btn-primary {
  background-color: #667eea;
  color: white;
  border: none;
}

.btn-secondary {
  background-color: #f0f0f0;
  color: #666;
  border: 1rpx solid #ddd;
}

.btn-outline {
  background-color: transparent;
  color: #667eea;
  border: 1rpx solid #667eea;
}

/* 卡片样式 */
.card {
  background: white;
  border-radius: 15rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
}

/* 输入框样式 */
.input-field {
  width: 100%;
  height: 80rpx;
  padding: 0 20rpx;
  border: 1rpx solid #e5e5e5;
  border-radius: 10rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.textarea-field {
  width: 100%;
  min-height: 120rpx;
  padding: 20rpx;
  border: 1rpx solid #e5e5e5;
  border-radius: 10rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

/* 图标样式 */
.icon {
  width: 40rpx;
  height: 40rpx;
  vertical-align: middle;
}

/* 加载动画 */
.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 60rpx 0;
}

/* 空状态 */
.empty-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
  text-align: center;
}

.empty-text {
  margin-top: 30rpx;
  color: #999;
  font-size: 28rpx;
}

/* 标签样式 */
.tag {
  display: inline-block;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  line-height: 1.4;
}

.tag-primary {
  background-color: #eef7ff;
  color: #4a90e2;
}

.tag-success {
  background-color: #ecf7ee;
  color: #5cb860;
}

.tag-warning {
  background-color: #fdf7e2;
  color: #f0ad4e;
}

.tag-danger {
  background-color: #fde9e9;
  color: #dd514c;
}

/* 弹窗样式 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  background: white;
  border-radius: 15rpx;
  padding: 40rpx;
  margin: 40rpx;
  max-width: 600rpx;
  width: 100%;
}

/* 过渡动画 */
.fade-in {
  animation: fadeIn 0.3s ease-in-out;
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}